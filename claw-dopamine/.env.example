# ─────────────────────────────────────────────────
# claw-dopamine service
# ─────────────────────────────────────────────────
DOPAMINE_PORT=8787
DOPAMINE_DATABASE_URL="file:./prisma/dev.db"

# Shared secret — must match DOPAMINE_SHARED_SECRET in claw-drugstore/.env
# Generate with: openssl rand -hex 32
DOPAMINE_SHARED_SECRET=dev-secret-change-me

# Public-facing base URL (used in QR pairing payloads)
# Set to your deployed URL in production (e.g. https://dopamine.yourdomain.com)
DOPAMINE_PUBLIC_URL=http://localhost:8787

# Dopamine decay/max settings
DOPAMINE_DECAY_PER_HOUR=2
DOPAMINE_MAX_LEVEL=100

# CORS (comma-separated list of allowed origins; leave unset for open dev access)
# Example for prod: CORS_ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
# CORS_ALLOWED_ORIGINS=
