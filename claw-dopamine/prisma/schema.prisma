generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DOPAMINE_DATABASE_URL")
  directUrl = env("DOPAMINE_DATABASE_URL")
}

model Account {
  id           String   @id @default(cuid())
  recoveryCode String
  createdAt    DateTime @default(now())

  devices        Device[]
  dopamine       DopamineState?
  events         DopamineEvent[]
  pairingInvites PairingInvite[]
  rewardTokens   RewardToken[]
}

model Device {
  id        String   @id @default(cuid())
  accountId String
  publicKey String
  label     String?
  createdAt DateTime @default(now())

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId])
  @@unique([accountId, publicKey])
}

model DopamineState {
  accountId String   @id
  level     Float    @default(0)
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)
}

model DopamineEvent {
  id        String   @id @default(cuid())
  accountId String
  delta     Float
  reason    String?
  metaJson  String?
  createdAt DateTime @default(now())

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId, createdAt])
}

model PairingInvite {
  code      String   @id
  accountId String
  createdAt DateTime @default(now())
  expiresAt DateTime
  usedAt    DateTime?

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId])
  @@index([expiresAt])
}

model RewardToken {
  code        String   @id
  accountId   String
  delta       Float
  effectJson  String?
  createdAt   DateTime @default(now())
  expiresAt   DateTime
  redeemedAt  DateTime?
  redeemedBy  String?

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId])
  @@index([expiresAt])
}
