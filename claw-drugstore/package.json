{
  "name": "claw-drugstore",
  "private": true,
  "workspaces": [
    "apps/*",
    "skills/*"
  ],
  "scripts": {
    "dev": "npm-run-all -p dev:store dev:site",
    "dev:store": "npm --workspace apps/drugstore-web run dev",
    "dev:site": "npm --workspace apps/drugstore-site run dev",
    "build": "npm --workspace apps/drugstore-web run build",
    "lint": "npm --workspace apps/drugstore-web run lint"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5"
  }
}
