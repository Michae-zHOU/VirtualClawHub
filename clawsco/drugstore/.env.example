# ─────────────────────────────────────────────────
# claw-dopamine service connection
# ─────────────────────────────────────────────────
# Server-side URL (used by Next.js API routes)
CLAWDOPAMINE_BASE_URL=http://localhost:8787
# Client-side URL (must be reachable from the browser)
NEXT_PUBLIC_CLAWDOPAMINE_BASE_URL=http://localhost:8787

# Shared secret for server → dopamine API calls
# MUST match DOPAMINE_SHARED_SECRET in claw-dopamine/.env
DOPAMINE_SHARED_SECRET=dev-secret-change-me

# ─────────────────────────────────────────────────
# claw-psyche service connection
# ─────────────────────────────────────────────────
NEXT_PUBLIC_PSYCHE_BASE_URL=http://localhost:8788

# ─────────────────────────────────────────────────
# drugstore-site (marketing site) URL
# ─────────────────────────────────────────────────
NEXT_PUBLIC_DRUGSTORE_SITE_URL=http://localhost:3001

# ─────────────────────────────────────────────────
# Dopamine service config (if running co-located)
# ─────────────────────────────────────────────────
DOPAMINE_PORT=8787
DOPAMINE_DATABASE_URL="file:./services/claw-dopamine/prisma/dev.db"
DOPAMINE_DECAY_PER_HOUR=2
DOPAMINE_MAX_LEVEL=100
# Public URL returned in QR pairing payloads (set to your deployed URL in prod)
DOPAMINE_PUBLIC_URL=http://localhost:8787

# ─────────────────────────────────────────────────
# Clawstore admin key (for protected admin routes)
# ─────────────────────────────────────────────────
CLAWSTORE_ADMIN_KEY=dev-admin-key-change-me

# ─────────────────────────────────────────────────
# Clawstore display name
# ─────────────────────────────────────────────────
NEXT_PUBLIC_CLAWSTORE_NAME=Clawstore
